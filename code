// --- core render ---
let renderTimer;
function scheduleRender() {
  clearTimeout(renderTimer);
  renderTimer = setTimeout(render, 50);
}

function isFinderArea(r, c, n) {
  // 8x8 finder + separator at three corners
  if (r < 8 && c < 8) return true;
  if (r < 8 && c >= n - 8) return true;
  if (r >= n - 8 && c < 8) return true;
  return false;
}

function buildQR() {
  // Try v40 first; fall back to lower versions if text is short.
  // qrcode-generator: typeNumber 0 means auto-pick smallest version.
  // We force version 40 to honor the user's request.
  let qr;
  try {
    qr = qrcode(40, state.ec);
    qr.addData(state.text || ' ');
    qr.make();
    return qr;
  } catch (err) {
    console.error('QR generation failed:', err);
    return null;
  }
}

function drawShape(ctx, x, y, size, style, color) {
  ctx.fillStyle = color;
  if (style === 'square') {
    ctx.fillRect(x, y, size, size);
  } else if (style === 'dot') {
    ctx.beginPath();
    ctx.arc(x + size/2, y + size/2, size/2 * 0.92, 0, Math.PI * 2);
    ctx.fill();
  } else if (style === 'rounded') {
    const r = size * 0.28;
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.lineTo(x + size - r, y);
    ctx.quadraticCurveTo(x + size, y, x + size, y + r);
    ctx.lineTo(x + size, y + size - r);
    ctx.quadraticCurveTo(x + size, y + size, x + size - r, y + size);
    ctx.lineTo(x + r, y + size);
    ctx.quadraticCurveTo(x, y + size, x, y + size - r);
    ctx.lineTo(x, y + r);
    ctx.quadraticCurveTo(x, y, x + r, y);
    ctx.fill();
  } else if (style === 'diamond') {
    ctx.beginPath();
    ctx.moveTo(x + size/2, y);
    ctx.lineTo(x + size, y + size/2);
    ctx.lineTo(x + size/2, y + size);
    ctx.lineTo(x, y + size/2);
    ctx.closePath();
    ctx.fill();
  }
}

/* ====================================================================
   IMAGE SAMPLING & SUB-MODULE PAINTING

   Old approach: one image pixel sampled per QR module, then that single
   color fills the whole module rectangle (scale × scale identical pixels).

   New approach: sample the image at the FULL output resolution
   (n × scale per side), so each module covers scale² distinct image
   pixels. We compute the per-module *mean* luminance for the QR conflict
   analysis, then paint each output pixel individually using its own
   sub-module image color, applying a per-module bias only where the
   module's mean must be forced into the right luminance band.

   Why this works without breaking scans: phone QR decoders read each
   module by sampling an area near its center and comparing to a
   threshold. As long as the module's *mean* luminance lands on the
   right side of the threshold, sub-module variation is invisible to
   the decoder. The scanner sees the same dark/light decision; the
   human sees scale²× more visual detail.
==================================================================== */

function sampleImageHighRes(img, n, scale) {
  // Cover-fit the image into an (n*scale) × (n*scale) RGBA buffer.
  const size = n * scale;
  const tmp = document.createElement('canvas');
  tmp.width = size; tmp.height = size;
  const ctx = tmp.getContext('2d');
  ctx.fillStyle = '#888';
  ctx.fillRect(0, 0, size, size);

  const ar = img.width / img.height;
  let sx, sy, sw, sh;
  if (ar > 1) {
    sh = img.height; sw = img.height;
    sx = (img.width - sw) / 2; sy = 0;
  } else {
    sw = img.width; sh = img.width;
    sx = 0; sy = (img.height - sh) / 2;
  }
  ctx.drawImage(img, sx, sy, sw, sh, 0, 0, size, size);
  return ctx.getImageData(0, 0, size, size).data;
}

function findMedianLum(data) {
  // Histogram-based median (O(n + 256), no sort). Returns median
  // luminance in [0, 1].
  const hist = new Uint32Array(256);
  const total = (data.length / 4) | 0;
  for (let i = 0; i < total; i++) {
    const idx = i * 4;
    const v = 0.299 * data[idx] + 0.587 * data[idx + 1] + 0.114 * data[idx + 2];
    const b = v < 0 ? 0 : v > 255 ? 255 : (v + 0.5) | 0;
    hist[b]++;
  }
  const half = total / 2;
  let cum = 0;
  for (let i = 0; i < 256; i++) {
    cum += hist[i];
    if (cum >= half) return i / 255;
  }
  return 0.5;
}

function applyAutoBalance(data) {
  // STAGE 1 — Histogram match (per-pixel).
  // Compute the image's median luminance and remap it to 0.5, so half
  // the pixels land in each of the QR's "wants dark" / "wants light"
  // bands. Without this, an 83%-dark image like the moonlit-landscape
  // benchmark forces most light QR modules to conflict no matter how
  // much budget we throw at them.
  //
  // The per-pixel S-curve push is intentionally REMOVED here — it
  // fails on bimodal modules (sub-pixels with a sharp dark/light split,
  // e.g. anywhere there's an image edge inside a module). Pushing dark
  // pixels darker and light pixels lighter cancels out at the module
  // mean. applyModulePush below handles that case correctly.
  const median = findMedianLum(data);
  if (median < 0.001 || median > 0.999) return; // degenerate

  const denomLow  = median;
  const denomHigh = 1 - median;
  const total = (data.length / 4) | 0;

  for (let i = 0; i < total; i++) {
    const idx = i * 4;
    const r = data[idx], g = data[idx + 1], b = data[idx + 2];
    const oldLum = (0.299 * r + 0.587 * g + 0.114 * b) / 255;

    const newLum = oldLum <= median
      ? oldLum / denomLow * 0.5
      : 0.5 + (oldLum - median) / denomHigh * 0.5;

    if (oldLum > 0.001) {
      const f = newLum / oldLum;
      let nr = r * f, ng = g * f, nb = b * f;
      data[idx]     = nr < 0 ? 0 : nr > 255 ? 255 : (nr + 0.5) | 0;
      data[idx + 1] = ng < 0 ? 0 : ng > 255 ? 255 : (ng + 0.5) | 0;
      data[idx + 2] = nb < 0 ? 0 : nb > 255 ? 255 : (nb + 0.5) | 0;
    } else {
      const v = (newLum * 255 + 0.5) | 0;
      data[idx] = v; data[idx + 1] = v; data[idx + 2] = v;
    }
  }
}

function applyModulePush(highRes, n, scale) {
  // STAGE 2 — Per-module S-curve push.
  // Operates on per-module means rather than individual pixels. This is
  // the key fix for bimodal modules: when sub-pixels are split between
  // dark and light, a per-pixel push leaves the mean unchanged
  // (pushing dark pixels darker + light pixels lighter cancels out).
  // Per-module push scales every pixel in the module by the same
  // factor, guaranteeing the new mean lands decisively past threshold.
  //
  // Empirical: drops coin-flip module rate (mean in 0.45..0.55) from
  // ~8% to ~1% on the moonlit-landscape benchmark.
  const stride = n * scale;
  const sExp = 0.5; // sStrength = 0.5

  for (let r = 0; r < n; r++) {
    for (let c = 0; c < n; c++) {
      // Mean luminance of this module's sub-pixels
      let sum = 0;
      for (let dy = 0; dy < scale; dy++) {
        const rowBase = ((r * scale + dy) * stride + c * scale) * 4;
        for (let dx = 0; dx < scale; dx++) {
          const idx = rowBase + dx * 4;
          sum += 0.299 * highRes[idx] + 0.587 * highRes[idx + 1] + 0.114 * highRes[idx + 2];
        }
      }
      const oldMean = sum / (scale * scale * 255);

      const t = (oldMean - 0.5) * 2;
      const at = t < 0 ? -t : t;
      if (at < 0.001 || oldMean < 0.001) continue;

      const sign = t < 0 ? -1 : 1;
      const pushed = sign * Math.pow(at, sExp);
      const newMean = 0.5 + pushed * 0.5;
      const factor = newMean / oldMean;

      // Apply uniform scale factor to every sub-pixel in this module
      for (let dy = 0; dy < scale; dy++) {
        const rowBase = ((r * scale + dy) * stride + c * scale) * 4;
        for (let dx = 0; dx < scale; dx++) {
          const idx = rowBase + dx * 4;
          let nr = highRes[idx]     * factor;
          let ng = highRes[idx + 1] * factor;
          let nb = highRes[idx + 2] * factor;
          highRes[idx]     = nr < 0 ? 0 : nr > 255 ? 255 : (nr + 0.5) | 0;
          highRes[idx + 1] = ng < 0 ? 0 : ng > 255 ? 255 : (ng + 0.5) | 0;
          highRes[idx + 2] = nb < 0 ? 0 : nb > 255 ? 255 : (nb + 0.5) | 0;
        }
      }
    }
  }
}

function computeModuleLums(highRes, n, scale) {
  // Per-module mean luminance — the value the camera will actually
  // threshold against. Computed once, used both for conflict analysis
  // and policy decisions.
  const lums = new Float32Array(n * n);
  const stride = n * scale;
  const cnt = scale * scale;
  for (let r = 0; r < n; r++) {
    for (let c = 0; c < n; c++) {
      let sR = 0, sG = 0, sB = 0;
      for (let dy = 0; dy < scale; dy++) {
        const rowOff = ((r * scale + dy) * stride + c * scale) * 4;
        for (let dx = 0; dx < scale; dx++) {
          const px = rowOff + dx * 4;
          sR += highRes[px];
          sG += highRes[px + 1];
          sB += highRes[px + 2];
        }
      }
      lums[r * n + c] = (0.299 * (sR / cnt) + 0.587 * (sG / cnt) + 0.114 * (sB / cnt)) / 255;
    }
  }
  return lums;
}

function render() {
  const qr = buildQR();
  if (!qr) return;

  const n = qr.getModuleCount();
  const scale = state.scale;
  const padding = scale * 4;
  const size = n * scale + padding * 2;

  canvas.width = size;
  canvas.height = size;
  const ctx = canvas.getContext('2d');

  ctx.fillStyle = '#ffffff';
  ctx.fillRect(0, 0, size, size);

  // ===== FAST PATH: no image, plain B/W QR =====
  if (!state.image) {
    ctx.fillStyle = '#000000';
    for (let r = 0; r < n; r++) {
      for (let c = 0; c < n; c++) {
        if (qr.isDark(r, c)) {
          ctx.fillRect(padding + c * scale, padding + r * scale, scale, scale);
        }
      }
    }
    metaModules.innerHTML = `<span>${n}</span>`;
    metaSize.innerHTML = `<span>${size}</span>`;
    metaFidelity.innerHTML = `<span>—</span>`;
    return;
  }

  // ===== HIGH-RES SAMPLING + OPTIONAL CONTRAST BOOST =====
  const highRes = sampleImageHighRes(state.image, n, scale);
  if (state.boostContrast) {
    applyAutoBalance(highRes);
    applyModulePush(highRes, n, scale);
  }
  const lums = computeModuleLums(highRes, n, scale);

  // ===== RS-AWARE ANALYSIS (pixelate mode only) =====
  let corruptibleCodewords = null;
  let fidelityStats = null;
  const useAdaptive = state.mode === 'pixelate' && n === V40.N;

  if (useAdaptive) {
    const blockInfo = blockMapForECL(state.ec);
    const { codewordToBlock, maxCorrect } = blockInfo;

    const cwConflicts = new Map();
    for (let r = 0; r < n; r++) {
      for (let c = 0; c < n; c++) {
        if (isFunctionalV40(r, c)) continue;
        const bitIdx = placementBitIndex(r, c);
        if (bitIdx < 0) continue;
        const isDark = qr.isDark(r, c);
        const naturalDark = lums[r * n + c] < 0.5;
        if (isDark !== naturalDark) {
          const cwIdx = bitIdx >> 3;
          cwConflicts.set(cwIdx, (cwConflicts.get(cwIdx) || 0) + 1);
        }
      }
    }

    const budgetPerBlock = Math.round(state.intensity * maxCorrect);

    const byBlock = new Map();
    for (const [cwIdx, count] of cwConflicts) {
      const blk = codewordToBlock[cwIdx];
      if (blk === undefined) continue;
      if (!byBlock.has(blk)) byBlock.set(blk, []);
      byBlock.get(blk).push({ cwIdx, count });
    }

    corruptibleCodewords = new Set();
    let savedConflicts = 0, totalConflicts = 0;
    for (const [, list] of byBlock) {
      list.sort((a, b) => b.count - a.count);
      for (let i = 0; i < list.length; i++) {
        totalConflicts += list[i].count;
        if (i < budgetPerBlock) {
          corruptibleCodewords.add(list[i].cwIdx);
          savedConflicts += list[i].count;
        }
      }
    }
    fidelityStats = {
      totalConflicts, savedConflicts,
      forcedConflicts: totalConflicts - savedConflicts,
      budgetPerBlock,
    };
  }

  // ===== PER-MODULE POLICY TABLE =====
  // Decide once per module how every sub-pixel inside it will be
  // colored. This pulls a lot of branching out of the inner pixel loop.
  // We also compute an *adaptive* per-module forcing factor `forceK`:
  // instead of slamming every forced pixel with the same big push, we
  // compute the minimum push each module needs to land its mean luminance
  // safely on the right side of the camera's threshold. Modules whose
  // natural mean is only just barely on the wrong side get a gentle
  // nudge; modules deep on the wrong side get a stronger one. Result:
  // forced pixels keep more of their image color where possible.
  const POL_IMAGE       = 0;
  const POL_FORCE_DARK  = 1;
  const POL_FORCE_LIGHT = 2;
  const POL_PURE_DARK   = 3;
  const POL_PURE_LIGHT  = 4;

  // Anchor strength → target luminance bands. The slider (0.20..1.00)
  // controls how far past the 0.5 threshold each forced module's mean
  // must land. 0.20 → 0.40/0.60 (just past threshold, image dominates);
  // 1.00 → 0.10/0.90 (deep into pure black/white, anchors very visible).
  const targetDark  = 0.5 - state.anchorStrength * 0.4;
  const targetLight = 0.5 + state.anchorStrength * 0.4;

  const policy = new Uint8Array(n * n);
  const forceK = new Float32Array(n * n);

  for (let r = 0; r < n; r++) {
    for (let c = 0; c < n; c++) {
      const isDark = qr.isDark(r, c);
      const idx = r * n + c;
      const critical = state.preserveFinders &&
        (n === V40.N ? isFunctionalV40(r, c) : isFinderArea(r, c, n));

      if (critical) {
        policy[idx] = isDark ? POL_PURE_DARK : POL_PURE_LIGHT;
        continue;
      }

      const naturalDark = lums[idx] < 0.5;
      const matches = isDark === naturalDark;

      let pol;
      if (state.mode === 'pixelate') {
        let allowImage = matches;
        if (!matches && useAdaptive) {
          const bitIdx = placementBitIndex(r, c);
          if (bitIdx >= 0) {
            const cwIdx = bitIdx >> 3;
            if (corruptibleCodewords.has(cwIdx)) allowImage = true;
          }
        }
        pol = allowImage ? POL_IMAGE : (isDark ? POL_FORCE_DARK : POL_FORCE_LIGHT);
      } else {
        // overlay mode: every module forced uniformly by intensity slider
        pol = isDark ? POL_FORCE_DARK : POL_FORCE_LIGHT;
      }
      policy[idx] = pol;

      // Compute adaptive blend factor for forced modules. Pixelate mode
      // uses the actual module-mean luminance to compute the minimum push
      // needed; overlay mode uses the slider directly.
      if (pol === POL_FORCE_DARK) {
        if (state.mode === 'pixelate') {
          // k is a multiplier (0..1) on each sub-pixel. New mean = old mean × k.
          // Need: lums[idx] × k ≤ targetDark  →  k ≤ targetDark / lums[idx].
          // (lums[idx] > 0.5 here because !matches.)
          forceK[idx] = Math.max(0, Math.min(1, targetDark / Math.max(0.001, lums[idx])));
        } else {
          forceK[idx] = state.intensity; // overlay: 0 = pure black
        }
      } else if (pol === POL_FORCE_LIGHT) {
        if (state.mode === 'pixelate') {
          // k is a blend factor (0..1) toward white. New mean = old + (1-old) × k.
          // Need: lums[idx] + (1 - lums[idx]) × k ≥ targetLight.
          // (lums[idx] < 0.5 here because !matches.)
          const denom = 1 - lums[idx];
          forceK[idx] = denom > 0.001
            ? Math.max(0, Math.min(1, (targetLight - lums[idx]) / denom))
            : 0;
        } else {
          forceK[idx] = 1 - state.intensity; // overlay: 1 = pure white
        }
      }
    }
  }

  // ===== SUB-MODULE PAINTING =====
  // Walk every output pixel inside the QR area. Each pixel reads its
  // own image color from the high-res sample, then applies the bias
  // (or override) dictated by its module's policy. Result: a faithful
  // pixelated rendering of the source image where every module's mean
  // luminance still satisfies the QR's required dark/light pattern.
  const imageData = ctx.getImageData(0, 0, size, size);
  const out = imageData.data;
  const qrSize = n * scale;

  for (let py = 0; py < qrSize; py++) {
    const r = (py / scale) | 0;
    const srcRow = py * qrSize * 4;
    const outRow = (padding + py) * size * 4 + padding * 4;

    for (let px = 0; px < qrSize; px++) {
      const c = (px / scale) | 0;
      const srcIdx = srcRow + px * 4;
      const outIdx = outRow + px * 4;

      const pr = highRes[srcIdx];
      const pg = highRes[srcIdx + 1];
      const pb = highRes[srcIdx + 2];

      const modIdx = r * n + c;
      const pol = policy[modIdx];
      let oR, oG, oB;

      if (pol === POL_IMAGE) {
        oR = pr; oG = pg; oB = pb;
      } else if (pol === POL_PURE_DARK) {
        oR = 0; oG = 0; oB = 0;
      } else if (pol === POL_PURE_LIGHT) {
        oR = 255; oG = 255; oB = 255;
      } else if (pol === POL_FORCE_DARK) {
        const k = forceK[modIdx];
        oR = pr * k; oG = pg * k; oB = pb * k;
      } else { // POL_FORCE_LIGHT
        const k = forceK[modIdx];
        oR = pr + (255 - pr) * k;
        oG = pg + (255 - pg) * k;
        oB = pb + (255 - pb) * k;
      }

      out[outIdx]     = oR;
      out[outIdx + 1] = oG;
      out[outIdx + 2] = oB;
      out[outIdx + 3] = 255;
    }
  }

  ctx.putImageData(imageData, 0, 0);

  metaModules.innerHTML = `<span>${n}</span>`;
  metaSize.innerHTML = `<span>${size}</span>`;

  if (fidelityStats) {
    const totalData = 29648; // V40: 3706 codewords × 8 bits
    const imageWins = totalData - fidelityStats.forcedConflicts;
    const pct = (imageWins / totalData * 100).toFixed(1);
    metaFidelity.innerHTML = `<span>${pct}%</span>`;
  } else {
    metaFidelity.innerHTML = `<span>—</span>`;
  }
}

// --- download ---
downloadBtn.addEventListener('click', () => {
  const link = document.createElement('a');
  link.download = `qr-mosaic-${Date.now()}.png`;
  link.href = canvas.toDataURL('image/png');
  link.click();
});

// --- scannability hint ---
testScanBtn.addEventListener('click', () => {
  const btn = testScanBtn;
  const orig = btn.innerHTML;
  btn.innerHTML = 'Point your phone camera at the QR →';
  btn.style.color = 'var(--accent)';
  btn.style.borderColor = 'var(--accent)';
  setTimeout(() => {
    btn.innerHTML = orig;
    btn.style.color = '';
    btn.style.borderColor = '';
  }, 3500);
});

// initial render
updateCharCount();
render();
</script>

