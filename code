  // text-mode counter (full readout with capacity warning)
  charCount.textContent = `${len} / ${cap} chars`;
  charCount.className = 'char-count';
  if (len > cap) charCount.classList.add('error');
  else if (len > cap * 0.85) charCount.classList.add('warn');

